# Linty — Signing & Notarization
# Copy to .env and fill in your values.

# Code signing (auto-detected from Keychain if installed)
# APPLE_SIGNING_IDENTITY="Developer ID Application: Hari Shekhar (3RPKRQ84N3)"

# Notarization (use app-specific password from appleid.apple.com)
# APPLE_ID="your@email.com"
# APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="3RPKRQ84N3"
